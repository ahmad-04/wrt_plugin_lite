QWidget { background-color: #ffffff; }
QLabel { color: #2c3e50; font-size: 12px; }
QLineEdit, QSpinBox, QDateTimeEdit, QComboBox {
    border: 1px solid #c0cdd8;
    border-radius: 4px;
    padding: 4px 8px;
    background-color: #ffffff;
    color: #2c2c2c;
}
QLineEdit:focus, QSpinBox:focus, QDateTimeEdit:focus, QComboBox:focus {
    border: 1px solid #5ba3d9;
}
QComboBox::drop-down { border: none; width: 20px; }
QTableWidget {
    border: 1px solid #dce3ea;
    border-radius: 4px;
    gridline-color: #eaf0f5;
    background-color: #ffffff;
    selection-background-color: #dceef9;
    selection-color: #1e3a5f;
}
QTableWidget QHeaderView::section {
    background-color: #eaf0f6;
    color: #1e3a5f;
    font-weight: bold;
    padding: 6px;
    border: none;
    border-right: 1px solid #d0dce8;
    border-bottom: 1px solid #d0dce8;
}
QPushButton {
    background-color: #2e6da4;
    color: white;
    border: none;
    border-radius: 4px;
    padding: 6px 14px;
    font-size: 12px;
}
QPushButton:hover { background-color: #3a85c4; }
QPushButton:pressed { background-color: #1e5a8a; }
QPushButton#btnClearRoute {
    background-color: #e8edf2;
    color: #2c3e50;
}
QPushButton#btnClearRoute:hover { background-color: #d5dde6; }
QPlainTextEdit {
    border: 1px solid #dce3ea;
    border-radius: 4px;
    background-color: #f9fbfc;
    color: #2c2c2c;
    font-family: Consolas, monospace;
    font-size: 12px;
    padding: 8px;
}
QCheckBox { color: #2c3e50; font-size: 12px; }
QCheckBox::indicator {
    width: 16px; height: 16px;
    border: 1px solid #c0cdd8;
    border-radius: 3px;
    background-color: white;
}
QCheckBox::indicator:checked {
    background-color: #2e6da4;
    border-color: #2e6da4;
}
    </string>
